// Tokens de design compartilhados
export global AppStyle {
    // Cores principais
    out property <color> primary: #1565C0;
    out property <color> primary-light: #1E88E5;
    out property <color> primary-dark: #0D47A1;
    out property <color> accent: #FF6F00;
    out property <color> accent-light: #FFA000;

    // Cores de fundo
    out property <color> bg-main: #F5F5F5;
    out property <color> bg-surface: #FFFFFF;
    out property <color> bg-sidebar: #1E1E2E;
    out property <color> bg-sidebar-hover: #2A2A3E;

    // Cores de texto
    out property <color> text-primary: #212121;
    out property <color> text-secondary: #757575;
    out property <color> text-on-primary: #FFFFFF;
    out property <color> text-on-sidebar: #E0E0E0;

    // Status
    out property <color> recording-red: #EF5350;
    out property <color> success-green: #66BB6A;
    out property <color> warning-yellow: #FFA726;

    // Dimensoes
    out property <length> sidebar-width: 200px;
    out property <length> border-radius: 8px;
    out property <length> spacing: 16px;
    out property <length> spacing-small: 8px;
}
