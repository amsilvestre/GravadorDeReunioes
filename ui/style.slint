// Tokens de design compartilhados
export global AppStyle {
    in-out property <bool> dark_theme: false;

    // Cores principais
    out property <color> primary: #1565C0;
    out property <color> primary-light: #1E88E5;
    out property <color> primary-dark: #0D47A1;
    out property <color> accent: #FF6F00;
    out property <color> accent-light: #FFA000;

    // Cores de fundo
    out property <color> bg-main: dark_theme ? #101418 : #F5F5F5;
    out property <color> bg-surface: dark_theme ? #182028 : #FFFFFF;
    out property <color> bg-sidebar: dark_theme ? #0A0D12 : #1E1E2E;
    out property <color> bg-sidebar-hover: dark_theme ? #151A24 : #2A2A3E;

    // Cores de texto
    out property <color> text-primary: dark_theme ? #F3F4F6 : #212121;
    out property <color> text-secondary: dark_theme ? #A8B0BA : #757575;
    out property <color> text-on-primary: #FFFFFF;
    out property <color> text-on-sidebar: dark_theme ? #D7DCE2 : #E0E0E0;

    // Status
    out property <color> recording-red: #EF5350;
    out property <color> success-green: #66BB6A;
    out property <color> warning-yellow: #FFA726;

    // Dimensoes
    out property <length> sidebar-width: 200px;
    out property <length> border-radius: 10px;
    out property <length> border-radius-small: 6px;
    out property <length> spacing: 16px;
    out property <length> spacing-small: 8px;

    // Cores auxiliares
    out property <color> divider: dark_theme ? #26303A : #EEEEEE;
}
