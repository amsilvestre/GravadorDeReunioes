import { Button, VerticalBox, HorizontalBox, ScrollView, ComboBox, ProgressIndicator, LineEdit } from "std-widgets.slint";
import { AppStyle } from "style.slint";

export struct TranscriptionSegment {
    timestamp: string,
    text: string,
}

export component TranscriptionPanel inherits Rectangle {
    background: AppStyle.bg-surface;
    border-radius: AppStyle.border-radius;
    vertical-stretch: 1;

    // Propriedades de entrada
    in property <string> engine: "cloud";
    in property <[TranscriptionSegment]> segments: [];
    in property <float> progress: 0.0;
    in property <bool> is-transcribing: false;
    in property <string> status-text: "";
    in property <string> duration-text: "";
    in property <bool> has-recording: false;

    // Propriedade de busca
    in-out property <string> search-text: "";

    // Callbacks
    callback transcribe();
    callback open-audio-file();
    callback copy-to-clipboard();
    callback export-text();
    callback search-changed(string);

    VerticalBox {
        padding: AppStyle.spacing;
        spacing: AppStyle.spacing;

        // Cabecalho
        HorizontalBox {
            spacing: AppStyle.spacing;
            alignment: start;

            Text {
                text: "Transcricao";
                font-size: 20px;
                font-weight: 600;
                color: AppStyle.text-primary;
                vertical-alignment: center;
            }

            Rectangle { horizontal-stretch: 1; }

            if (root.has-recording || root.is-transcribing) && !root.is-transcribing: Button {
                text: "🎙 Transcrever";
                primary: true;
                clicked => { root.transcribe(); }
            }

            if !root.is-transcribing: Button {
                text: "📂 Abrir Áudio";
                clicked => { root.open-audio-file(); }
            }

            if root.segments.length > 0: Button {
                text: "📋 Copiar";
                clicked => { root.copy-to-clipboard(); }
            }

            if root.segments.length > 0: Button {
                text: "💾 Exportar";
                clicked => { root.export-text(); }
            }
        }

        // Campo de busca
        if root.segments.length > 0: HorizontalBox {
            spacing: AppStyle.spacing-small;

            Rectangle {
                width: 200px;
                height: 32px;
                border-radius: 4px;
                background: AppStyle.bg-main;

                search-input := LineEdit {
                    placeholder-text: "Buscar no texto...";
                    text <=> root.search-text;
                    height: 100%;
                    width: 100%;
                    edited(value) => { root.search-changed(value); }
                }
            }

            Button {
                text: "🔍 Buscar";
                clicked => { root.search-changed(root.search-text); }
            }

            if root.search-text != "": Text {
                text: "Pressione Enter ou clique em Buscar";
                font-size: 11px;
                color: AppStyle.text-secondary;
                vertical-alignment: center;
            }
        }

        // Texto de status (sempre visivel quando houver mensagem)
        if root.status-text != "": Text {
            text: root.status-text;
            font-size: 14px;
            color: AppStyle.text-secondary;
        }

        if root.duration-text != "": Text {
            text: root.duration-text;
            font-size: 12px;
            color: AppStyle.text-secondary;
        }

        // Barra de progresso durante transcricao
        if is-transcribing: ProgressIndicator {
            progress: root.progress;
            height: 6px;
        }

        // Lista de segmentos transcritos
        if root.segments.length > 0: ScrollView {
            vertical-stretch: 1;

            VerticalBox {
                spacing: AppStyle.spacing-small;

                for segment in root.segments: HorizontalBox {
                    spacing: AppStyle.spacing-small;

                    Text {
                        text: segment.timestamp;
                        font-size: 12px;
                        color: AppStyle.primary;
                        font-weight: 600;
                        width: 60px;
                    }

                    Text {
                        text: segment.text;
                        font-size: 15px;
                        color: AppStyle.text-primary;
                        wrap: word-wrap;
                        horizontal-stretch: 1;
                    }
                }
            }
        }

        // Placeholder quando nao ha transcricao e sem status
        if root.segments.length == 0 && !root.is-transcribing && root.status-text == "": Rectangle {
            vertical-stretch: 1;

            Text {
                text: root.has-recording ? "Clique em 'Transcrever' para iniciar" : "Grave uma reuniao primeiro";
                font-size: 16px;
                color: AppStyle.text-secondary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
