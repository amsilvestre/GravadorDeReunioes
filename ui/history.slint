import { Button, VerticalBox, HorizontalBox, ScrollView, LineEdit } from "std-widgets.slint";
import { AppStyle } from "style.slint";

export struct RecordingItem {
    id: int,
    name: string,
    date: string,
    duration: string,
    status: string,   // "none" | "done" | "error"
}

export component HistoryPanel inherits Rectangle {
    background: AppStyle.bg-surface;
    border-radius: AppStyle.border-radius;

    in property <[RecordingItem]> recordings: [];
    in-out property <int> selected-id: -1;

    // id do item sendo renomeado (-1 = nenhum)
    private property <int> renaming-id: -1;
    private property <string> rename-buffer: "";

    callback refresh();
    callback load-recording(int);
    callback delete-recording(int);
    callback rename-recording(int, string);

    VerticalBox {
        padding: AppStyle.spacing;
        spacing: AppStyle.spacing;

        // Cabecalho
        HorizontalBox {
            spacing: AppStyle.spacing;
            alignment: start;
            height: 36px;

            Text {
                text: "Historico";
                font-size: 20px;
                font-weight: 600;
                color: AppStyle.text-primary;
                vertical-alignment: center;
            }

            Rectangle { horizontal-stretch: 1; }

            Button {
                text: "Atualizar";
                clicked => { root.refresh(); }
            }
        }

        // Lista de gravacoes
        if root.recordings.length > 0: ScrollView {
            vertical-stretch: 1;

            VerticalBox {
                spacing: AppStyle.spacing-small;

                for rec in root.recordings: Rectangle {
                    height: root.renaming-id == rec.id ? 80px : 64px;
                    border-radius: AppStyle.border-radius-small;
                    background: rec.id == root.selected-id
                        ? AppStyle.primary-light.with-alpha(0.12)
                        : AppStyle.bg-main;
                    border-width: rec.id == root.selected-id ? 2px : 1px;
                    border-color: rec.id == root.selected-id
                        ? AppStyle.primary
                        : #E0E0E0;

                    // Seleciona ao clicar (apenas quando nao esta renomeando)
                    TouchArea {
                        enabled: root.renaming-id != rec.id;
                        clicked => { root.selected-id = rec.id; }
                    }

                    VerticalBox {
                        padding: AppStyle.spacing-small;
                        spacing: 4px;

                        // Linha principal: dot + nome + acoes
                        HorizontalBox {
                            spacing: AppStyle.spacing-small;
                            alignment: start;
                            height: 32px;

                            // Indicador de status
                            Rectangle {
                                width: 8px;
                                height: 8px;
                                border-radius: 4px;
                                y: (parent.height - self.height) / 2;
                                background: rec.status == "done"
                                    ? AppStyle.success-green
                                    : rec.status == "error"
                                        ? AppStyle.recording-red
                                        : AppStyle.warning-yellow;
                            }

                            // Nome (ou campo de edicao)
                            if root.renaming-id != rec.id: Text {
                                text: rec.name;
                                font-size: 13px;
                                font-weight: 600;
                                color: AppStyle.text-primary;
                                overflow: elide;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            if root.renaming-id == rec.id: LineEdit {
                                text: root.rename-buffer;
                                horizontal-stretch: 1;
                                edited(val) => { root.rename-buffer = val; }
                                accepted(val) => {
                                    root.rename-recording(rec.id, val);
                                    root.renaming-id = -1;
                                }
                            }

                            // Botoes de acao (sempre visiveis)
                            if root.renaming-id != rec.id: HorizontalBox {
                                spacing: 4px;
                                alignment: end;

                                // Botao Renomear
                                Rectangle {
                                    width: 28px;
                                    height: 28px;
                                    border-radius: 4px;
                                    background: rename-touch.has-hover
                                        ? AppStyle.primary-light.with-alpha(0.15)
                                        : transparent;

                                    rename-touch := TouchArea {
                                        clicked => {
                                            root.renaming-id = rec.id;
                                            root.rename-buffer = rec.name;
                                        }
                                    }

                                    Text {
                                        text: "✏";
                                        font-size: 14px;
                                        color: AppStyle.text-secondary;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                // Botao Excluir
                                Rectangle {
                                    width: 28px;
                                    height: 28px;
                                    border-radius: 4px;
                                    background: del-touch.has-hover
                                        ? AppStyle.recording-red.with-alpha(0.12)
                                        : transparent;

                                    del-touch := TouchArea {
                                        clicked => {
                                            root.delete-recording(rec.id);
                                            if root.selected-id == rec.id {
                                                root.selected-id = -1;
                                            }
                                        }
                                    }

                                    Text {
                                        text: "🗑";
                                        font-size: 14px;
                                        color: AppStyle.recording-red;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Botoes de confirmar/cancelar rename
                            if root.renaming-id == rec.id: HorizontalBox {
                                spacing: 4px;
                                alignment: end;

                                Button {
                                    text: "OK";
                                    primary: true;
                                    clicked => {
                                        root.rename-recording(rec.id, root.rename-buffer);
                                        root.renaming-id = -1;
                                    }
                                }

                                Button {
                                    text: "X";
                                    clicked => { root.renaming-id = -1; }
                                }
                            }
                        }

                        // Linha secundaria: metadados
                        if root.renaming-id != rec.id: HorizontalBox {
                            spacing: AppStyle.spacing-small;
                            alignment: start;
                            padding-left: 16px;

                            Text {
                                text: rec.date;
                                font-size: 11px;
                                color: AppStyle.text-secondary;
                            }

                            Text { text: "•"; font-size: 11px; color: AppStyle.text-secondary; }

                            Text {
                                text: rec.duration;
                                font-size: 11px;
                                color: AppStyle.text-secondary;
                            }

                            Text { text: "•"; font-size: 11px; color: AppStyle.text-secondary; }

                            Text {
                                text: rec.status == "done" ? "Transcrito"
                                    : rec.status == "error" ? "Erro" : "Pendente";
                                font-size: 11px;
                                color: rec.status == "done" ? AppStyle.success-green
                                    : rec.status == "error" ? AppStyle.recording-red
                                    : AppStyle.warning-yellow;
                            }
                        }
                    }
                }
            }
        }

        // Placeholder quando sem gravacoes
        if root.recordings.length == 0: Rectangle {
            vertical-stretch: 1;

            Text {
                text: "Nenhuma gravacao encontrada";
                font-size: 14px;
                color: AppStyle.text-secondary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // Botao de carregar
        if root.selected-id >= 0: Button {
            text: "Carregar Gravacao Selecionada";
            primary: true;
            clicked => { root.load-recording(root.selected-id); }
        }
    }
}
