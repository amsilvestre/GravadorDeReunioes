import { Button, VerticalBox, HorizontalBox, ComboBox, LineEdit, Switch, ScrollView } from "std-widgets.slint";
import { AppStyle } from "style.slint";

export component SettingsPanel inherits Rectangle {
    background: AppStyle.bg-surface;
    border-radius: AppStyle.border-radius;

    // Propriedades
    in-out property <int> engine-index: 0;  // 0 = Cloud, 1 = Local
    in-out property <int> theme_index: 0;
    in-out property <int> model-index: 0;
    in-out property <int> language-index: 0;
    in-out property <int> hardware-index: 0;
    in-out property <int> input-device-index: 0;
    in-out property <int> output-device-index: 0;
    in-out property <string> api-key: "";
    in-out property <string> output-dir: "";
    in property <[string]> available-models: ["tiny", "base", "small", "medium", "large"];
    in property <[string]> engine-options: ["Cloud (OpenAI)", "Local (Whisper)"];
    in property <[string]> theme-options: ["Claro", "Escuro"];
    in property <[string]> language-options: ["Portugues", "Ingles", "Espanhol", "Frances", "Alemao", "Italiano", "Japones", "Chines", "Automatico"];
    in property <[string]> hardware-options: ["CPU"];
    in property <[string]> device-options: ["Dispositivo Padrao"];
    in property <bool> gpu-available: false;

    // Callbacks
    callback save-settings();
    callback api-key-changed(string);
    callback engine-changed(int);
    callback model-changed(int);
    callback theme-changed(int);
    callback language-changed(int);
    callback hardware-changed(int);
    callback input-device-changed(int);
    callback output-device-changed(int);
    callback select-output-folder();
    callback load-devices();

    ScrollView {
        VerticalBox {
            padding: AppStyle.spacing;
            spacing: AppStyle.spacing;

            Text {
                text: "Configuracoes";
                font-size: 20px;
                font-weight: 600;
                color: AppStyle.text-primary;
            }

            // Engine de transcricao
            VerticalBox {
                spacing: AppStyle.spacing-small;

                Text {
                    text: "Motor de Transcricao";
                    font-size: 14px;
                    font-weight: 500;
                    color: AppStyle.text-primary;
                }

                ComboBox {
                    model: root.engine-options;
                    current-index <=> root.engine-index;
                    selected(value) => { root.engine-changed(self.current-index); }
                }
            }

            // Idioma
            VerticalBox {
                spacing: AppStyle.spacing-small;

                Text {
                    text: "Idioma";
                    font-size: 14px;
                    font-weight: 500;
                    color: AppStyle.text-primary;
                }

                ComboBox {
                    model: root.language-options;
                    current-index <=> root.language-index;
                    selected(value) => { root.language-changed(self.current-index); }
                }

                Text {
                    text: "Idioma para transcricao. Automatico detecta automaticamente.";
                    font-size: 12px;
                    color: AppStyle.text-secondary;
                    wrap: word-wrap;
                }
            }

            // CPU / GPU
            if engine-index == 1: VerticalBox {
                spacing: AppStyle.spacing-small;

                Text {
                    text: "Hardware";
                    font-size: 14px;
                    font-weight: 500;
                    color: AppStyle.text-primary;
                }

                ComboBox {
                    model: root.gpu-available ? ["CPU", "GPU"] : ["CPU"];
                    current-index <=> root.hardware-index;
                    selected(value) => { root.hardware-changed(self.current-index); }
                }

                if root.gpu-available: Text {
                    text: "GPU disponivel neste computador.";
                    font-size: 12px;
                    color: AppStyle.success-green;
                }
                if !root.gpu-available: Text {
                    text: "GPU nao detectada. Usando CPU.";
                    font-size: 12px;
                    color: AppStyle.text-secondary;
                }
            }

            VerticalBox {
                spacing: AppStyle.spacing-small;

                Text {
                    text: "Tema";
                    font-size: 14px;
                    font-weight: 500;
                    color: AppStyle.text-primary;
                }

                ComboBox {
                    model: root.theme-options;
                    current-index <=> root.theme-index;
                    selected(value) => { root.theme-changed(self.current-index); }
                }
            }

            // API Key (so mostra se engine = cloud)
            if engine-index == 0: VerticalBox {
                spacing: AppStyle.spacing-small;

                Text {
                    text: "Chave API OpenAI";
                    font-size: 14px;
                    font-weight: 500;
                    color: AppStyle.text-primary;
                }

                LineEdit {
                    text <=> root.api-key;
                    placeholder-text: "sk-...";
                    input-type: password;
                    edited(value) => { root.api-key-changed(value); }
                }
            }

            // Modelo local (so mostra se engine = local)
            if engine-index == 1: VerticalBox {
                spacing: AppStyle.spacing-small;

                Text {
                    text: "Modelo Whisper";
                    font-size: 14px;
                    font-weight: 500;
                    color: AppStyle.text-primary;
                }

                ComboBox {
                    model: root.available-models;
                    current-index <=> root.model-index;
                    selected(value) => { root.model-changed(self.current-index); }
                }

                Text {
                    text: "Modelos maiores sao mais precisos, mas mais lentos em CPU.";
                    font-size: 12px;
                    color: AppStyle.text-secondary;
                    wrap: word-wrap;
                }
            }

            // Pasta de saida
            VerticalBox {
                spacing: AppStyle.spacing-small;

                Text {
                    text: "Pasta de Saida";
                    font-size: 14px;
                    font-weight: 500;
                    color: AppStyle.text-primary;
                }

                Text {
                    text: root.output-dir == "" ? "As gravacoes serao salvas nesta pasta." : root.output-dir;
                    font-size: 12px;
                    color: AppStyle.text-secondary;
                    wrap: word-wrap;
                }

                HorizontalBox {
                    spacing: AppStyle.spacing-small;

                    Button {
                        text: "Selecionar Pasta";
                        clicked => { root.select-output-folder(); }
                    }
                }
            }

            // Dispositivo de entrada (microfone)
            VerticalBox {
                spacing: AppStyle.spacing-small;

                Text {
                    text: "Microfone";
                    font-size: 14px;
                    font-weight: 500;
                    color: AppStyle.text-primary;
                }

                ComboBox {
                    model: root.device-options;
                    current-index <=> root.input-device-index;
                    selected(value) => { root.input-device-changed(self.current-index); }
                }
            }

            // Dispositivo de saida (audio do sistema)
            VerticalBox {
                spacing: AppStyle.spacing-small;

                Text {
                    text: "Audio do Sistema (Loopback)";
                    font-size: 14px;
                    font-weight: 500;
                    color: AppStyle.text-primary;
                }

                ComboBox {
                    model: root.device-options;
                    current-index <=> root.output-device-index;
                    selected(value) => { root.output-device-changed(self.current-index); }
                }

                Text {
                    text: "Audio que sai pelas caixas/saida.";
                    font-size: 12px;
                    color: AppStyle.text-secondary;
                    wrap: word-wrap;
                }
            }

            Rectangle { vertical-stretch: 1; }

            // Botao salvar
            HorizontalBox {
                alignment: end;

                Button {
                    text: "Salvar";
                    primary: true;
                    clicked => { root.save-settings(); }
                }
            }
        }
    }
}