import { Button, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { AppStyle } from "style.slint";
import { RecordingPanel } from "recording.slint";
import { TranscriptionPanel, TranscriptionSegment } from "transcription.slint";
import { SettingsPanel } from "settings.slint";
import { HistoryPanel, RecordingItem } from "history.slint";

export { TranscriptionSegment }
export { RecordingItem }
export { AppStyle }

component SidebarButton inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    in property <image> icon;

    callback clicked();

    height: 48px;
    background: touch.has-hover ? AppStyle.bg-sidebar-hover :
                active ? AppStyle.bg-sidebar-hover : transparent;
    border-radius: AppStyle.border-radius;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    // Indicador lateral esquerdo quando ativo
    if root.active: Rectangle {
        x: 0;
        y: (parent.height - self.height) / 2;
        width: 3px;
        height: 24px;
        border-radius: 2px;
        background: AppStyle.primary-light;
    }

    HorizontalBox {
        padding-left: AppStyle.spacing;
        padding-right: AppStyle.spacing;
        alignment: start;
        spacing: AppStyle.spacing-small;

        Text {
            text: root.label;
            font-size: 14px;
            color: root.active ? AppStyle.text-on-primary : AppStyle.text-on-sidebar;
            vertical-alignment: center;
            font-weight: root.active ? 600 : 400;
        }
    }
}

export component AppWindow inherits Window {
    title: "AMS Gravador de reuniões";
    icon: @image-url("app.ico");
    // Reasonable default size, resizable within limits
    preferred-width: 900px;
    preferred-height: 650px;
    min-width: 600px;
    min-height: 400px;
    max-width: 1200px;
    max-height: 800px;
    background: AppStyle.bg-main;

    // Estado da pagina ativa: 0=Gravar, 1=Historico, 2=Config
    in-out property <int> active-page: 0;

    // Controle do dialogo Sobre
    private property <bool> show-about: false;

    // Controle do dialogo de atualizacao
    in-out property <bool> show-update-dialog: false;
    in-out property <string> update-version: "";
    in-out property <string> update-url: "";
    in-out property <string> update-body: "";
    in-out property <bool> is-checking-update: false;

    // === Propriedades de gravacao ===
    in property <bool> is-recording: false;
    in property <bool> is-paused: false;
    in-out property <int> recording_delay_index: 0;
    in property <string> recording-duration: "00:00:00";
    in property <float> audio-level: 0.0;
    in property <string> recording-status: "Pronto para gravar";

    // === Propriedades de transcricao ===
    in property <string> transcription-engine: "cloud";
    in property <[TranscriptionSegment]> transcription-segments: [];
    in property <float> transcription-progress: 0.0;
    in property <bool> is-transcribing: false;
    in property <string> transcription-status: "";
    in property <string> transcription-duration: "";
    in property <bool> has-recording: false;
    in-out property <string> transcription-search: "";

    // === Propriedades de configuracao ===
    in-out property <int> engine-index: 0;
    in-out property <int> theme_index: 0;
    in-out property <int> model-index: 0;
    in-out property <int> language-index: 0;
    in-out property <int> hardware-index: 0;
    in-out property <int> input-device-index: 0;
    in-out property <int> output-device-index: 0;
    in-out property <string> api-key: "";
    in-out property <string> output-dir: "";
    in property <[string]> input-devices: [];
    in property <[string]> output-devices: [];
    in property <bool> gpu-available: false;

    // === Propriedades de historico ===
    in property <[RecordingItem]> recordings: [];
    in-out property <int> selected-recording-id: -1;

    // === Callbacks ===
    callback start-recording();
    callback stop-recording();
    callback pause-recording();
    callback resume-recording();
    callback transcribe();
    callback open-audio-file();
    callback copy-to-clipboard();
    callback export-text();
    callback save-settings();
    callback transcription-search-changed(string);
    callback api-key-changed(string);
    callback engine-changed(int);
    callback theme-changed(int);
    callback model-changed(int);
    callback language-changed(int);
    callback hardware-changed(int);
    callback input-device-changed(int);
    callback output-device-changed(int);
    callback select-output-folder();
    callback load-devices();
    callback load-recordings();
    callback select-recording(int);
    callback delete-recording(int);
    callback rename-recording(int, string);
    callback check-for-updates();
    callback download-and-install-update();

    HorizontalBox {
        // Sidebar
        Rectangle {
            width: AppStyle.sidebar-width;
            background: AppStyle.bg-sidebar;

            VerticalBox {
                padding: AppStyle.spacing-small;
                spacing: 4px;

                // Logo / Titulo
                VerticalBox {
                    height: 72px;
                    spacing: 0px;
                    padding: 0px;
                    alignment: center;

                    Text {
                        text: "AMS";
                        font-size: 13px;
                        font-weight: 400;
                        color: AppStyle.primary-light;
                        horizontal-alignment: center;
                        letter-spacing: 3px;
                    }

                    Text {
                        text: "Gravador";
                        font-size: 18px;
                        font-weight: 700;
                        color: AppStyle.text-on-primary;
                        horizontal-alignment: center;
                    }
                }

                SidebarButton {
                    label: "🎙 Gravar";
                    active: root.active-page == 0;
                    clicked => { root.active-page = 0; }
                }

                SidebarButton {
                    label: "📜 Historico";
                    active: root.active-page == 1;
                    clicked => { root.active-page = 1; }
                }

                SidebarButton {
                    label: "⚙ Configuracoes";
                    active: root.active-page == 2;
                    clicked => { root.active-page = 2; }
                }

                Rectangle { vertical-stretch: 1; }

                // Indicador de status no rodape da sidebar
                Text {
                    text: root.is-recording ? "Gravando..." : "Ocioso";
                    font-size: 11px;
                    color: root.is-recording ? AppStyle.recording-red : AppStyle.text-on-sidebar;
                    horizontal-alignment: center;
                    height: 24px;
                    vertical-alignment: center;
                }

                // Botao Sobre
                Rectangle {
                    height: 36px;
                    border-radius: AppStyle.border-radius-small;
                    background: about-touch.has-hover
                        ? AppStyle.bg-sidebar-hover
                        : transparent;

                    about-touch := TouchArea {
                        clicked => { root.show-about = true; }
                    }

                    Text {
                        text: "ℹ Sobre";
                        font-size: 12px;
                        color: #9E9EBE;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Area de conteudo principal
        Rectangle {
            horizontal-stretch: 1;

            VerticalBox {
                padding: AppStyle.spacing;
                spacing: AppStyle.spacing;

                // Pagina de gravacao
                if root.active-page == 0: VerticalBox {
                    spacing: AppStyle.spacing;
                    vertical-stretch: 1;

                    rec := RecordingPanel {
                        is-recording: root.is-recording;
                        is-paused: root.is-paused;
                        delay_index <=> root.recording_delay_index;
                        duration: root.recording-duration;
                        audio-level: root.audio-level;
                        status-text: root.recording-status;
                        start-recording => { root.start-recording(); }
                        stop-recording => { root.stop-recording(); }
                        pause-recording => { root.pause-recording(); }
                        resume-recording => { root.resume-recording(); }
                    }

                        trans := TranscriptionPanel {
                        vertical-stretch: 1;
                        segments: root.transcription-segments;
                        progress: root.transcription-progress;
                        is-transcribing: root.is-transcribing;
                        status-text: root.transcription-status;
                        duration-text: root.transcription-duration;
                        has-recording: root.has-recording;
                        search-text <=> root.transcription-search;
                        search-changed(text) => { root.transcription-search-changed(text); }
                        transcribe => { root.transcribe(); }
                        open-audio-file => { root.open-audio-file(); }
                        copy-to-clipboard => { root.copy-to-clipboard(); }
                        export-text => { root.export-text(); }
                    }
                }

                // Pagina de historico
                if root.active-page == 1: HistoryPanel {
                    vertical-stretch: 1;
                    recordings: root.recordings;
                    selected-id <=> root.selected-recording-id;
                    refresh => { root.load-recordings(); }
                    load-recording(id) => { root.select-recording(id); }
                    delete-recording(id) => { root.delete-recording(id); }
                    rename-recording(id, name) => { root.rename-recording(id, name); }
                }

                // Pagina de configuracoes
                if root.active-page == 2: SettingsPanel {
                    engine-index <=> root.engine-index;
                    theme_index <=> root.theme_index;
                    model-index <=> root.model-index;
                    language-index <=> root.language-index;
                    hardware-index <=> root.hardware-index;
                    input-device-index <=> root.input-device-index;
                    output-device-index <=> root.output-device-index;
                    api-key <=> root.api-key;
                    output-dir <=> root.output-dir;
                    device-options: root.input-devices;
                    gpu-available: root.gpu-available;
                    save-settings => { root.save-settings(); }
                    api-key-changed(key) => { root.api-key-changed(key); }
                    engine-changed(idx) => { root.engine-changed(idx); }
                    theme-changed(idx) => { root.theme-changed(idx); }
                    model-changed(idx) => { root.model-changed(idx); }
                    language-changed(idx) => { root.language-changed(idx); }
                    hardware-changed(idx) => { root.hardware-changed(idx); }
                    input-device-changed(idx) => { root.input-device-changed(idx); }
                    output-device-changed(idx) => { root.output-device-changed(idx); }
                    select-output-folder => { root.select-output-folder(); }
                }
            }
        }
    }

    // === Dialogo "Sobre" (overlay) ===
    if root.show-about: Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: #00000080;

        // Fecha ao clicar no fundo
        TouchArea {
            clicked => { root.show-about = false; }
        }

        // Card central
        Rectangle {
            width: 460px;
            height: 360px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: AppStyle.bg-surface;
            border-radius: AppStyle.border-radius;
            drop-shadow-blur: 24px;
            drop-shadow-color: #00000040;
            drop-shadow-offset-y: 8px;

            // Impede que cliques no card fechem o dialogo
            TouchArea {}

            VerticalBox {
                padding: 32px;
                spacing: AppStyle.spacing;
                alignment: start;

                // Cabecalho
                HorizontalBox {
                    spacing: AppStyle.spacing-small;
                    alignment: start;

                    // Icone decorativo
                    Rectangle {
                        width: 40px;
                        height: 40px;
                        border-radius: 10px;
                        background: AppStyle.primary;

                        Text {
                            text: "🎙";
                            font-size: 20px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    VerticalBox {
                        spacing: 2px;
                        padding: 0px;
                        alignment: center;

                        Text {
                            text: "AMS Gravador de reuniões";
                            font-size: 17px;
                            font-weight: 700;
                            color: AppStyle.text-primary;
                        }

                        Text {
                            text: "Versao 1.0";
                            font-size: 12px;
                            color: AppStyle.text-secondary;
                        }
                    }
                }

                // Divisor
                Rectangle {
                    height: 1px;
                    background: AppStyle.divider;
                }

                // Descricao
                Text {
                    text: "Programa para gravar reuniões ou áudio do microfone e transcrever para texto usando Whisper (Local ou Cloud).";
                    font-size: 13px;
                    color: AppStyle.text-primary;
                    wrap: word-wrap;
                }

                Text {
                    text: "Transcrição disponível em:";
                    font-size: 13px;
                    color: AppStyle.text-primary;
                    wrap: word-wrap;
                }

                // Bullets de engines
                HorizontalBox {
                    spacing: AppStyle.spacing-small;
                    padding-left: 8px;

                    Rectangle {
                        width: 6px;
                        height: 6px;
                        border-radius: 3px;
                        background: AppStyle.primary;
                        y: 6px;
                    }

                    Text {
                        text: "Whisper Cloud — OpenAI API (requer chave de API)";
                        font-size: 13px;
                        color: AppStyle.text-secondary;
                        wrap: word-wrap;
                        horizontal-stretch: 1;
                    }
                }

                HorizontalBox {
                    spacing: AppStyle.spacing-small;
                    padding-left: 8px;

                    Rectangle {
                        width: 6px;
                        height: 6px;
                        border-radius: 3px;
                        background: AppStyle.primary;
                        y: 6px;
                    }

                    Text {
                        text: "Whisper Local — Modelos rodando na CPU, sem internet";
                        font-size: 13px;
                        color: AppStyle.text-secondary;
                        wrap: word-wrap;
                        horizontal-stretch: 1;
                    }
                }

                Rectangle { vertical-stretch: 1; }

                // Botao fechar
                HorizontalBox {
                    alignment: end;

                    Button {
                        text: "Fechar";
                        clicked => { root.show-about = false; }
                    }
                }
            }
        }
    }

    // === Dialogo "Atualizacao" (overlay) ===
    if root.show-update-dialog: Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: #00000080;

        // Fecha ao clicar no fundo
        TouchArea {
            clicked => { root.show-update-dialog = false; }
        }

        // Card central
        Rectangle {
            width: 420px;
            height: 280px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: AppStyle.bg-surface;
            border-radius: AppStyle.border-radius;
            drop-shadow-blur: 24px;
            drop-shadow-color: #00000040;
            drop-shadow-offset-y: 8px;

            // Impede que cliques no card fechem o dialogo
            TouchArea {}

            VerticalBox {
                padding: 28px;
                spacing: AppStyle.spacing;
                alignment: start;

                // Cabecalho
                HorizontalBox {
                    spacing: AppStyle.spacing-small;
                    alignment: start;

                    Rectangle {
                        width: 40px;
                        height: 40px;
                        border-radius: 10px;
                        background: AppStyle.success-green;

                        Text {
                            text: "🚀";
                            font-size: 20px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    VerticalBox {
                        spacing: 2px;
                        padding: 0px;
                        alignment: center;

                        Text {
                            text: "Atualização Disponivel!";
                            font-size: 17px;
                            font-weight: 700;
                            color: AppStyle.text-primary;
                        }

                        Text {
                            text: "Versao " + root.update-version;
                            font-size: 12px;
                            color: AppStyle.text-secondary;
                        }
                    }
                }

                // Divisor
                Rectangle {
                    height: 1px;
                    background: AppStyle.divider;
                }

                // Descricao da atualizacao
                if root.update-body != "": Text {
                    text: root.update-body;
                    font-size: 13px;
                    color: AppStyle.text-primary;
                    wrap: word-wrap;
                    max-height: 80px;
                }

                if root.update-body == "": Text {
                    text: "Uma nova versão do Gravador de Reuniões está disponível. Clique em 'Baixar e Instalar' para atualizar.";
                    font-size: 13px;
                    color: AppStyle.text-primary;
                    wrap: word-wrap;
                }

                Rectangle { vertical-stretch: 1; }

                // Botoes
                HorizontalBox {
                    spacing: AppStyle.spacing-small;
                    alignment: end;

                    Button {
                        text: "Agora Não";
                        clicked => { root.show-update-dialog = false; }
                    }

                    Button {
                        text: "⬇️ Baixar e Instalar";
                        primary: true;
                        clicked => { root.download-and-install-update(); }
                    }
                }
            }
        }
    }
}
